# nginx-proxy / acme-companion: VIRTUAL_HOST matches the hostname nginx-proxy routes to this container.
# Leave LETSENCRYPT_EMAIL empty when userver-web/letsencrypt/.env sets DEFAULT_EMAIL once.
VIRTUAL_HOST=
LETSENCRYPT_HOST=
LETSENCRYPT_EMAIL=

POSTGRES_HOST=
POSTGRES_DB=
POSTGRES_DB_TEST=
POSTGRES_USER=
POSTGRES_PASS=
POSTGRES_PORT=5432

# prod → sslmode=require to Postgres (see userver-auth lib/db.go). Orchestration defaults USERVER_AUTH_ENV_MODE=dev
# for Docker Postgres without TLS; use prod when Postgres has TLS (userver-datamgr prod + ACME or RDS).
ENV_MODE=dev
BCRYPT_COST=13

APP_PORT=5000
APP_SECRET_KEY=
SYSTEM_CREATION_TOKEN=

JWT_EXP_DELTA_SECS=3600
JWT_REFRESH_DELTA_SECS=259200

POSTGRES_ROOT_USER=
POSTGRES_ROOT_PASS=

SKIP_DB_SETUP=0

# Do not set for Docker Hub image (deploy strips if present). Dev bind-mount only:
# MIGRATE_BIN=./out/userver-auth
# APP_BIN=./out/userver-auth
