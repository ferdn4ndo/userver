# dev: deploy sets nginx-proxy HTTPS_METHOD=noredirect so http://vhost:NGINX_HTTP_PORT works (redirect would send browsers to https on :443).
USERVER_MODE=dev
USERVER_FORCE_BUILD=true

# When true, clone_repo runs sudo chown on each userver-* dir before git (fixes root-owned files from Docker bind mounts on EC2, etc.).
USERVER_REPO_SUDO_CHOWN=false
# When true, existing clones are reset to origin on deploy (destructive: drops local commits/changes in service repos).
USERVER_REPO_GIT_RESET_HARD=false

#
# uServer Web
#
USERVER_SKIP_DEPLOY_WEB=false
USERVER_VIRTUAL_HOST=
USERVER_LETSENCRYPT_EMAIL=
# Host ports published by userver-nginx-proxy (written to userver-web/.env for docker compose). Defaults 80 / 443 if unset.
# Use e.g. 8880 / 8843 when port 80 is taken or for rootless Docker (see userver-web/.env.example).
USERVER_NGINX_HTTP_PORT=
USERVER_NGINX_HTTPS_PORT=
# Host filesystem path to the Docker API socket for compose bind mounts (not a unix:// URL — that breaks volume syntax).
# Rootless example: /run/user/1000/docker.sock (deploy strips a mistaken unix:// prefix if present).
USERVER_DOCKER_HOST_SOCK=
# If true, deploy does not write userver-web/docker-compose.override.yml with group_add (docker socket GID). Use when
# Docker returns setgroups: invalid argument (some rootless/user-namespace setups); ensure the socket is readable then.
# Deploy detects the socket GID as seen inside a container (busybox); Docker Desktop/WSL often maps the socket to
# nobody (65534), which differs from the host "docker" group — host-only stat would still yield permission denied.
USERVER_NGINX_PROXY_SKIP_DOCKER_GROUP_ADD=
# Optional override for nginx-proxy / acme / monitor (written to userver-web/.env as NGINX_PROXY_DOCKER_HOST).
# Default: unix:///var/run/docker.sock (compose mounts the host socket at that path in each container).
# Rootless Docker: processes in containers often cannot connect() to a bind-mounted docker.sock (EACCES) even with
# group_add; expose the engine on 127.0.0.1 and use TCP instead, e.g. tcp://host.docker.internal:2375 — see
# https://docs.docker.com/engine/security/rootless/#exposing-docker-api-socket-to-tcp-127001
# Bind only to loopback; do not expose 2375 on untrusted networks.
USERVER_NGINX_PROXY_DOCKER_HOST=
# nginx-proxy + many compose files: docker-gen in userver-nginx-proxy queries the whole Docker engine once per host.
# It sees every running container, from every compose project, as long as they are on the same daemon. Each stack that
# should be served still needs its HTTP services on the external network "nginx-proxy" and VIRTUAL_HOST (plus
# VIRTUAL_PORT when the app is not on 80). Deploy scripts call prepare_virtual_host / set VIRTUAL_PORT where needed.
# group_add for the socket applies only to userver-web services that mount docker.sock (proxy, letsencrypt, monitor),
# not to datamgr/auth/filemgr/mailer/logger stacks — those are backends docker-gen discovers automatically.
#
USERVER_MONITOR_HOSTNAME=monitor
USERVER_MONITOR_REFRESH_EVERY_SECONDS=1
USERVER_MONITOR_STATS_FILE=/usr/share/nginx/html/stats.txt
USERVER_WHOAMI_HOSTNAME=whoami

#
