USERVER_LOGGER_MONITOR_EXCLUDED_CONTAINER_NAMES=userver-loki;userver-grafana;userver-promtail;userver-container-monitor;userver-mosquitto;userver-rabbitmq
USERVER_LOGGER_MONITOR_LOOP_WAIT_INTERVAL=5s
USERVER_LOGGER_GRAFANA_ADMIN_USER=
